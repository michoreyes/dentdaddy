---
import '../styles/global.css'
import { Font } from 'astro:assets';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  theme?: "light" | "dark" | "gradient";
}


const { 
  title = "Dent Daddy Repair",
  description = "Professional paintless dent repair in Winnipeg, Manitoba. Fast, affordable, and flawless repairs for hail damage, door dings, and more.",
  theme = "gradient"
 } = Astro.props; 

---

<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.ico">
    <Font cssVariable='--font-dm' />
    <title>{title}</title>
    <meta name="description" content={description}>
  
  </head>
  <body>
    <slot/>
  </body>
</html>

<style is:global>
  body {
    background: var(--color-bg);
  }
</style>