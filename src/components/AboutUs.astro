---
import Proof from "./Proof.astro";
import { Image } from "astro:assets";
import photo from '../images/photo-16.jpg'
import Accordion from "./ui/Accordion.astro";
---

<section class="container">
  <h1 class="header">About Us</h1>
  <p class="sub-header">At Dent Daddy Repair, we specialize in paintless dent repair that restores your vehicle’s factory finish without paint or fillers. Our skilled technicians handle everything from minor dings to hail damage, working quickly and reliably to keep your car looking its best.</p>
  <p class="sub-header">With expert technicians, years of experience, and a commitment to quality, we make sure every repair is done quickly and seamlessly. From minor door dings to hail damage, our paint less dent repair keeps your vehicle looking factory fresh — no repainting, no fuss.</p>
  <div class="image-container">
    <Image src={photo} alt="car" width={1600} height={900}  />
  </div>
  <div class="accordion-container">
    <Accordion/>
  </div>

</section>

<style>
  
  .container {
    width: 100%;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    padding: 4rem 0;
  }
  .header{
    color: var(--color-offWhite);
    font-family: var(--font-dm);
    font-size: var(--text-display);
    margin-bottom: 3rem;
    font-weight: 600;
  }

  .sub-header {
    color: var(--color-offWhite);
    font-family: var(--font-dm);
    font-size: var(--text-base);
    line-height: 1.3;
    padding: 1rem 0;
  }

  .image-container {
    aspect-ratio: 16/9;
    padding: 2rem 0;
  }
  
  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .accordion-container {
    max-width: 50rem;
    margin: 0 auto;
    width: 100%;
    padding: 2rem 0 5rem 0;
  }

  @media (max-width:1280px) {
    .container{
      padding: 1rem 2rem;
    }
  }

  @media (max-width: 480px) {
    .image-container {
      aspect-ratio: 1/1;
    }
  }

</style>