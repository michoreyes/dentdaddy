---
import dlogo from "../images/dlogo.png"
import dlogolight from "../images/dlogo-light.png"
import { Image } from "astro:assets"

interface Props {
  variant?: "light" | "dark"
}

const { variant = "dark" } = Astro.props;
const isLight = variant === "light";
---

<header class={isLight ? "header-light" : "header-dark"}>
  <nav class="container">
    <a href="/">
      <Image 
        src={isLight ? dlogolight : dlogo} 
        alt="logo" 
        class="logo"
        width={10}
        height={40}
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <button class="burger" id="burger" aria-label="Toggle menu" aria-expanded="false">
      <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>

    <ul class="navlinks" id="navlinks">
      <li><a href="/service">Services</a></li>
      <li><a href="/about">About Us</a></li>
      <li><a href="/gallery">Gallery</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </nav>
</header>

<script>
  const burger = document.getElementById("burger");
  const navlinks = document.getElementById("navlinks");

  burger?.addEventListener("click", () => {
    const isOpen = navlinks?.classList.toggle("open");
    burger.classList.toggle("open");
    burger.setAttribute("aria-expanded", String(isOpen));
  });

  navlinks?.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", () => {
      navlinks.classList.remove("open");
      burger?.classList.remove("open");
      burger?.setAttribute("aria-expanded", "false");
    });
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 1rem 1.5rem;
    transition: background 0.3s ease, backdrop-filter 0.3s ease;
  }

  header.scrolled {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header-light {
    background: #fff;
  }

  .header-dark {
    background: transparent;
  }

  .container {
    width: 100%;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    height: 40px;
    width: auto;
  }

  .burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-offWhite);
  }

  .header-light .burger {
    color: var(--color-offBlack);
  }

  .icon-close {
    display: none;
  }

  .burger.open .icon-menu {
    display: none;
  }

  .burger.open .icon-close {
    display: block;
  }

  .navlinks {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .navlinks a {
    text-decoration: none;
    color: var(--color-offWhite);
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-dm);
    transition: opacity 0.15s ease;
  }

  .header-light .navlinks a {
    color: var(--color-offBlack);
  }

  .navlinks a:hover {
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .burger {
      display: flex;
    }

    .navlinks {
      display: none;
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      width: 70%;
      flex-direction: column;
      gap: 0;
      padding: 5rem 2rem 2rem;
      z-index: 50;
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      transform: translateX(100%);
      transition: transform 0.3s ease;
    }

    .navlinks.open {
      display: flex;
      transform: translateX(0);
    }

    .navlinks li {
      padding: 0.75rem 0;
      border-bottom: 1px solid color-mix(in srgb, var(--color-offWhite) 10%, transparent);
    }

    .navlinks li:last-child {
      border-bottom: none;
    }
  }
</style>