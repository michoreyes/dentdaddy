---
import Button from "./ui/Button.astro"
---

<section class="container">
  <h1 class="header">Commercial Paintless Dent Repair</h1>
  <p class="sub-header">Serving Winnipeg, Manitoba, and neighboring areas with fast, flawless repairs.</p>
  <Button href="/contact" size="lg">Get a Quote</Button>
</section>

<style>
  .container {
    width: 100%;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    padding: 7rem 0;
    z-index: 50;
    position: relative;
  }
  .header{
    color: var(--color-offWhite);
    font-family: var(--font-dm);
    font-size: var(--text-h1);
    line-height: 1.2;
    font-weight: 600;
    max-width: 40rem;
  }

  .sub-header{
    color: var(--color-offWhite);
    font-family: var(--font-dm);
    font-size: var(--text-lg);
    line-height: 1.3;
    margin: 1rem 0 3rem 0;
    max-width: 30rem;
  }

  @media (max-width:1280px) {
    .container{
      padding: 1rem 2rem;
    }
  }
</style>