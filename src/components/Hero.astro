---
import { Image } from "astro:assets";
import herocar from '../images/herocar.png'


---

<section class="container"  >
  <div class="text-content">
    <h1 class="hero-header">Experience Flawless Dent Repair Today</h1>
    <p class="hero-subheader">We specialize in restoring your car’s body to its original condition, making every dent and scratch disappear with precision and care.</p>
  </div> 

  <div class="image-container" id="herocar" >
    <Image src={herocar} alt="black car" width={herocar.width} height={herocar.height} loading="eager" fetchpriority="high" />
  </div>
</section>

<script>
import { animate, inView } from "motion"

  if (window.innerWidth > 768) {
    inView("#herocar", () => {
      animate(
        "#herocar",
        { opacity: [0, 1], transform: ["translateX(2rem)", "translateX(0)"]  },
        { duration: 1.2, easing: [0.16, 1, 0.3, 1] }
      )

      return () => {
        animate("#herocar", { opacity: 0, transform: "translateX(2rem)" }, { duration: 0 });
      }
    })
  }
</script>


<style>
  .hero-header{
    color: var(--color-offWhite);
    font-family: var(--font-dm);
    font-size: var(--text-h1);
    line-height: 1.1;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .hero-subheader{
    color: var(--color-offWhite);
    font-family: var(--font-dm);
    font-size: var(--text-lg);
    line-height: 1.3;
  }
  .container {
    width: 100%;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8rem 2rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .text-content {
    flex: 1 1 300px;
  }

  .image-container {  
    flex: 1 1 300px;
    display: flex;
    justify-content: center;
    overflow: hidden;
    opacity: 0;
  }

  .image-container img {
    max-width: 100%;
    height: auto;
    
  }

  @media (min-width: 769px) {
    .image-container {
      transform: translateX(2rem);
    }
  }

  @media (max-width: 768px) {
    .image-container {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .container {
      padding: 5rem 1rem;
    }
    
    .hero-header{
      text-align: center;
    }

    .hero-subheader{
      text-align: center;
    }
    
  }



</style>

