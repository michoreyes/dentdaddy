---
import Instructions from "../components/ui/Instruct.astro"
---

<section style="background-color: white;">
  <div class="container">
    <h1 class="steps-header" id="steps-header">
      <span class="line">Getting started is easy. Just send us photos or stop by for </span>
      <span class="line">a quick damage assessment—either through our online </span>
      <span class="line">form or an in-person visit. Then, schedule the repair as a </span>
      <span class="line">drop-off, mobile service, or shop appointment. Once the </span>
      <span class="line">work is complete, we’ll return your vehicle looking like new.</span>
  </div>

  <div class="ins-container">
    <Instructions />
  </div>
</section>

<script>
  import { inView, animate, stagger } from "motion"

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isMobile = window.innerWidth <= 878;

  if (!prefersReducedMotion && !isMobile) {
     document.querySelectorAll(".line").forEach((line) => {
      (line as HTMLElement).style.opacity = "0";
    });

    let lastScroll = window.scrollY;

    inView("#steps-header", () => {
      const currentScroll = window.scrollY;
      const scrollingDown = currentScroll > lastScroll;
      lastScroll = currentScroll;

      const fromY = scrollingDown ? "translateY(1rem)" : "translateY(-1rem)";

      animate(
        ".line",
        {
          opacity: [0, 1],
          filter: ["blur(4px)", "blur(0px)"],
          transform: [fromY, "translateY(0)"]
        },
        {
          duration: 0.8,
          easing: [0.16, 1, 0.3, 1],
          delay: scrollingDown ? stagger(0.15) : stagger(0.15, { from: "last" })
        }
      );
      

      return () => {
        lastScroll = window.scrollY;
        animate(
          ".line",
          { opacity: 0, filter: "blur(4px)", transform: fromY },
          { duration: 0 }
        );
      };  
    });
  } else {
    animate(".line", { opacity: 1 }, { duration: 0 });
  }


</script>

<style>
  .container {
    width: 100%;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    padding: 7rem 0 3rem 0;
  }

  .steps-header{
    font-family: var(--font-dm);
    font-size: var(--text-h3);
    line-height: 1.3;
    display: flex;
    flex-direction: column;
  }

  .line {
    display: block;
    overflow: hidden;
    opacity: 1;
  }

  .ins-container {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width:878px) {
    .steps-header {
      display: block;
      flex-direction: unset;
    }
    .line {
      display: inline;
      overflow: unset;
      opacity: 1 !important;
    }
  }

  @media (max-width:1280px) {
    .container{
      padding: 5rem 2rem;
    }
  }
</style>